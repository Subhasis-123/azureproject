{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "acharjee-factory"
		},
		"AzureDataLakeStorage1_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage1'"
		},
		"FileLocation_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'FileLocation'"
		},
		"azure_sql_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'azure_sql'"
		},
		"datalake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'datalake'"
		},
		"AzureDataLakeStorage1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://acharjee.dfs.core.windows.net/"
		},
		"FileLocation_properties_typeProperties_host": {
			"type": "string",
			"defaultValue": " C:\\Users\\Subhasis Acharjee\\Downloads\\Azure Project\\CRM+Sales+Opportunities"
		},
		"FileLocation_properties_typeProperties_userId": {
			"type": "string",
			"defaultValue": "subhasis acharjee"
		},
		"azure_sql_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "azureprojectsubhasis.database.windows.net"
		},
		"azure_sql_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "azureprojectdbsubh"
		},
		"azure_sql_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adminsubh"
		},
		"datalake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://acharjee.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "acharjee-factory_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorage1_accountKey": {
						"value": "[parameters('AzureDataLakeStorage1_accountKey')]"
					},
					"azure_sql_password": {
						"value": "[parameters('azure_sql_password')]"
					},
					"datalake_accountKey": {
						"value": "[parameters('datalake_accountKey')]"
					},
					"FileLocation_password": {
						"value": "[parameters('FileLocation_password')]"
					},
					"AzureDataLakeStorage1_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage1_properties_typeProperties_url')]"
					},
					"azure_sql_properties_typeProperties_server": {
						"value": "[parameters('azure_sql_properties_typeProperties_server')]"
					},
					"azure_sql_properties_typeProperties_database": {
						"value": "[parameters('azure_sql_properties_typeProperties_database')]"
					},
					"azure_sql_properties_typeProperties_userName": {
						"value": "[parameters('azure_sql_properties_typeProperties_userName')]"
					},
					"datalake_properties_typeProperties_url": {
						"value": "[parameters('datalake_properties_typeProperties_url')]"
					},
					"FileLocation_properties_typeProperties_host": {
						"value": "[parameters('FileLocation_properties_typeProperties_host')]"
					},
					"FileLocation_properties_typeProperties_userId": {
						"value": "[parameters('FileLocation_properties_typeProperties_userId')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}